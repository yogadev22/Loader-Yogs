<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:id="@+id/logo"
        android:layout_width="60dp"
        android:layout_height="60dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/yogs"/>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/menulayout"
        android:layout_width="380dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/dark">

        <LinearLayout
            android:id="@+id/nhn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@color/colorPrimary">

            <TextView
                android:id="@+id/closetext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:text="CLOSE" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/nhn"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/esptab"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:src="@drawable/esp"
                    android:background="@color/colorPrimary" />

                <ImageView
                    android:id="@+id/aimtab"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_marginTop="3sp"
                    android:src="@drawable/track"
                    android:background="@color/colorPrimary" />

                <ImageView
                    android:id="@+id/settingtab"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_marginTop="3sp"
                    android:src="@drawable/settings"
                    android:background="@color/colorPrimary" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/espmenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="3sp">

                <Switch
                    android:id="@+id/enableesp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4sp"
                    android:textSize="15sp"
                    android:text="Enable ESP"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2sp"
                    android:textSize="14sp"
                    android:textColor="@color/green_300"
                    android:text="ESP Selection"/>

                <CheckBox
                    android:id="@+id/espline"
                    android:layout_width="wrap_content"
                    android:layout_height="23dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:text="Line"/>

                <CheckBox
                    android:id="@+id/espbox"
                    android:layout_width="wrap_content"
                    android:layout_height="23dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:text="Box"/>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</FrameLayout>