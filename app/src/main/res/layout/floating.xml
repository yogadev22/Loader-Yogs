<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="wrap_content"
     android:layout_width="match_parent">

    <RelativeLayout
         android:layout_height="60dp"
         android:layout_width="60dp"
         android:id="@+id/logo">

        <ImageView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:src="@drawable/yogs" />

    </RelativeLayout>

    <RelativeLayout
         android:layout_height="match_parent"
         android:layout_width="380dp"
         android:background="@color/dark"
         android:orientation="vertical"
         android:id="@+id/menulayout">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:background="@color/colorPrimary"
             android:orientation="horizontal"
             android:id="@+id/nhn">

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:textSize="16sp"
                 android:textColor="@color/white"
                 android:id="@+id/closetext"
                 android:textStyle="bold"
                 android:text="YOGS LOADER" />

        </LinearLayout>

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_below="@+id/nhn"
             android:orientation="horizontal"
             android:layout_marginTop="5sp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="100dp"
                 android:orientation="vertical">

                <ImageView
                     android:layout_height="35dp"
                     android:layout_width="match_parent"
                     android:src="@drawable/esp"
                     android:background="@color/colorPrimary"
                     android:id="@+id/esptab" />

                <ImageView
                     android:layout_height="35dp"
                     android:layout_width="match_parent"
                     android:src="@drawable/track"
                     android:background="@color/colorPrimary"
                     android:layout_marginTop="3sp"
                     android:id="@+id/aimtab" />

                <ImageView
                     android:layout_height="35dp"
                     android:layout_width="match_parent"
                     android:src="@drawable/settings"
                     android:background="@color/colorPrimary"
                     android:layout_marginTop="3sp"
                     android:id="@+id/settingtab" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="vertical"
                 android:layout_marginStart="3sp"
                 android:id="@+id/espmenu">

                <Switch
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:textSize="15sp"
                     android:textColor="@color/white"
                     android:layout_marginStart="4sp"
                     android:id="@+id/enableesp"
                     android:text="Enable ESP" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:gravity="center_horizontal"
                     android:textSize="14sp"
                     android:textColor="@color/green_300"
                     android:text="ESP Selection" />

                <Switch
                     android:layout_height="23dp"
                     android:layout_width="match_parent"
                     android:textSize="15sp"
                     android:textColor="@color/white"
                     android:id="@+id/espline"
                     android:text="Line" />

                <Switch
                     android:layout_height="23dp"
                     android:layout_width="match_parent"
                     android:textSize="15sp"
                     android:textColor="@color/white"
                     android:id="@+id/espbox"
                     android:text="Box" />

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</FrameLayout>