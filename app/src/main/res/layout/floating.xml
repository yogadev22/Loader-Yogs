<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="wrap_content"
     android:layout_width="wrap_content">

    <RelativeLayout
         android:layout_height="50dp"
         android:layout_width="50dp"
         android:id="@+id/logo">

        <ImageView
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:src="@drawable/yogs"
             android:scaleType="centerCrop" />

    </RelativeLayout>

    <androidx.cardview.widget.CardView
         android:layout_height="350dp"
         android:layout_width="350dp"
         app:cardElevation="10dp"
         app:cardBackgroundColor="@color/dark"
         app:cardCornerRadius="16dp"
         android:id="@+id/menulayout">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:padding="8dp"
             android:orientation="vertical">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:background="@drawable/bg_button"
                 android:gravity="center"
                 android:padding="10dp"
                 android:id="@+id/nhn">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textColor="@color/white"
                     android:id="@+id/closetext"
                     android:text="YOGS INJECTOR"
                     android:textStyle="bold" />

            </LinearLayout>

            <View
                 android:layout_height="1dp"
                 android:layout_width="match_parent"
                 android:background="#FFFFFF"
                 android:alpha="0.2" />

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="horizontal"
                 android:layout_marginTop="6dp"
                 android:id="@+id/kaka">

                <Button
                     android:layout_height="35dp"
                     android:layout_width="80dp"
                     android:background="@drawable/bg_button"
                     android:textSize="14sp"
                     android:textColor="@color/white"
                     android:id="@+id/prevtab"
                     android:text="PREV" />

                <TextView
                     android:layout_height="35dp"
                     android:layout_width="0dp"
                     android:gravity="center"
                     android:textSize="14sp"
                     android:textColor="@color/white"
                     android:layout_weight="1"
                     android:id="@+id/texttab"
                     android:text="texttab" />

                <Button
                     android:layout_height="35dp"
                     android:layout_width="80dp"
                     android:background="@drawable/bg_button"
                     android:textSize="14sp"
                     android:textColor="@color/white"
                     android:layout_marginStart="6dp"
                     android:id="@+id/nexttab"
                     android:text="NEXT" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="vertical"
                 android:layout_marginTop="8dp"
                 android:id="@+id/espmenu">

                <ScrollView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:orientation="vertical">

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/espline"
                             android:text="Line" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/espbox"
                             android:text="Box" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/espname"
                             android:text="Name" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/espdistance"
                             android:text="Distance" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/esphealth"
                             android:text="Health" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/esp360alert"
                             android:text="360 Alert" />

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/espskipbot"
                             android:text="Skip Bot" />

                    </LinearLayout>

                </ScrollView>

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="vertical"
                 android:layout_marginTop="8dp"
                 android:id="@+id/aimmenu">

                <ScrollView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:orientation="vertical">

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/AimSilent"
                             android:text="Silent Aim" />

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:orientation="vertical">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:gravity="start"
                                 android:textSize="14sp"
                                 android:textColor="@color/green_300"
                                 android:text="Aim Position" />

                            <RadioGroup
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:orientation="vertical"
                                 android:id="@+id/radioaimpos">

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:checked="true"
                                     android:id="@+id/radio_head"
                                     android:tag="0"
                                     android:text="Head" />

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:id="@+id/radio_neck"
                                     android:tag="1"
                                     android:text="Neck" />

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:id="@+id/radio_chest"
                                     android:tag="2"
                                     android:text="Chest" />

                            </RadioGroup>

                        </LinearLayout>

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:orientation="vertical">

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:orientation="horizontal">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="15sp"
                                     android:textColor="#ffffff"
                                     android:text="Fov Circle : "
                                     android:textStyle="normal" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="15sp"
                                     android:textColor="#ffffff"
                                     android:id="@+id/textfov"
                                     android:text="0"
                                     android:textStyle="normal" />

                            </LinearLayout>

                            <SeekBar
                                 android:layout_height="match_parent"
                                 android:layout_width="match_parent"
                                 android:max="1500"
                                 android:progress="0"
                                 android:layout_weight="1"
                                 android:id="@+id/aimrange" />

                        </LinearLayout>

                        <Switch
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:textSize="15sp"
                             android:textColor="@color/white"
                             android:id="@+id/aimigbot"
                             android:text="Ignore Bot" />

                    </LinearLayout>

                </ScrollView>

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="vertical"
                 android:layout_marginTop="8dp"
                 android:id="@+id/setmenu">

                <ScrollView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:orientation="vertical">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:gravity="center"
                             android:textSize="14sp"
                             android:textColor="@color/green_300"
                             android:layout_marginTop="6dp"
                             android:text="Settings ESP" />

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:orientation="vertical">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:gravity="start"
                                 android:textSize="14sp"
                                 android:textColor="@color/green_300"
                                 android:text="Line Position" />

                            <RadioGroup
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:orientation="vertical"
                                 android:id="@+id/radioline">

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:checked="true"
                                     android:id="@+id/radio_top"
                                     android:tag="0"
                                     android:text="Top" />

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:id="@+id/radio_mid"
                                     android:tag="1"
                                     android:text="Mid" />

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:id="@+id/radio_bottom"
                                     android:tag="2"
                                     android:text="Bottom" />

                            </RadioGroup>

                        </LinearLayout>

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:background="@drawable/bg_switch"
                             android:layout_margin="6dp"
                             android:padding="10dp"
                             android:orientation="vertical">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:gravity="start"
                                 android:textSize="14sp"
                                 android:textColor="@color/green_300"
                                 android:text="Box Style" />

                            <RadioGroup
                                 android:layout_height="wrap_content"
                                 android:layout_width="match_parent"
                                 android:orientation="vertical"
                                 android:id="@+id/radiobox">

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:checked="true"
                                     android:id="@+id/radio_stroke"
                                     android:tag="0"
                                     android:text="Stroke" />

                                <RadioButton
                                     android:layout_height="wrap_content"
                                     android:layout_width="match_parent"
                                     android:textSize="14sp"
                                     android:textColor="@color/white"
                                     android:id="@+id/radio_filled"
                                     android:tag="1"
                                     android:text="Filled" />

                            </RadioGroup>

                        </LinearLayout>

                    </LinearLayout>

                </ScrollView>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</FrameLayout>