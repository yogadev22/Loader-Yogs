<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:tools="http://schemas.android.com/tools"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     tools:context=".MainActivity">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_marginEnd="16dp"
         android:gravity="center"
         android:background="@drawable/bg_rounded"
         android:orientation="vertical"
         android:layout_centerHorizontal="true"
         android:layout_marginTop="40dp"
        android:padding="10dp"
         android:layout_marginStart="16dp"
         app:cardCornerRadius="10dp"
         android:id="@+id/licenseinfo">

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:textSize="16sp"
             android:textStyle="bold"
             android:text="License Will Be Expire On" />

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="wrap_content"
             android:gravity="center"
             android:orientation="horizontal"
             android:layout_marginTop="12sp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:gravity="center"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="25dp"
                     android:layout_width="50dp"
                     android:gravity="center"
                     android:background="@color/white"
                     android:textSize="14sp"
                     android:textStyle="bold"
                     android:textColor="@color/black"
                     android:id="@+id/textday"
                     android:text="20" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textStyle="bold"
                     android:text="Day" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:gravity="center"
                 android:orientation="vertical"
                 android:layout_marginStart="12sp">

                <TextView
                     android:layout_height="25dp"
                     android:layout_width="50dp"
                     android:gravity="center"
                    android:textStyle="bold"
                     android:background="@color/white"
                     android:textSize="14sp"
                     android:textColor="@color/black"
                     android:id="@+id/texthour"
                     android:text="20" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textStyle="bold"
                     android:text="Hour" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:gravity="center"
                 android:orientation="vertical"
                 android:layout_marginStart="12sp">

                <TextView
                     android:layout_height="25dp"
                     android:layout_width="50dp"
                     android:gravity="center"
                    android:textStyle="bold"
                     android:background="@color/white"
                     android:textSize="14sp"
                     android:textColor="@color/black"
                     android:id="@+id/textminute"
                     android:text="20" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textStyle="bold"
                     android:text="Minute" />

            </LinearLayout>

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="wrap_content"
                 android:gravity="center"
                 android:orientation="vertical"
                 android:layout_marginStart="12sp">

                <TextView
                     android:layout_height="25dp"
                     android:layout_width="50dp"
                     android:gravity="center"
                    android:textStyle="bold"
                     android:background="@color/white"
                     android:textSize="14sp"
                     android:textColor="@color/black"
                     android:id="@+id/textsecond"
                     android:text="20" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="wrap_content"
                     android:textSize="16sp"
                     android:textStyle="bold"
                     android:text="Second" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/anjss"
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:layout_below="@id/licenseinfo"
         android:layout_marginEnd="16dp"
         android:orientation="horizontal"
         android:layout_marginTop="5dp"
         android:layout_marginStart="16dp"
        android:background="@drawable/bg_rounded"
        android:padding="10dp"
         app:cardCornerRadius="10dp">

        <ImageView
             android:layout_height="60dp"
             android:layout_width="60dp"
             android:src="@drawable/yogs" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOGS LOADER"
                android:layout_marginTop="5sp"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3sp"
                    android:text="Mode: "
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3sp"
                    android:text="Root"
                    android:textSize="15sp"/>

            </LinearLayout>

        </LinearLayout>

        <RelativeLayout
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:gravity="end">

            <com.google.android.material.button.MaterialButton
                 android:layout_height="50dp"
                 android:layout_width="wrap_content"
                 android:layout_marginTop="4dp"
                 android:layout_marginBottom="4dp"
                 android:textSize="16sp"
                 android:backgroundTint="#2E8B57"
                 android:textColor="#FFFFFF"
                 app:cornerRadius="10dp"
                 android:layout_gravity="end"
                 android:id="@+id/startbtn"
                 android:text="PLAY" />

        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/applist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/anjss"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="50dp"
        android:padding="10dp"
        android:background="@drawable/bg_rounded"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/ff"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Free Fire Max"
                    android:textColor="@color/white"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version: 2.120.1"
                    android:textColor="@color/white"
                    android:textSize="16sp"/>

            </LinearLayout>

            <RelativeLayout
                android:layout_height="match_parent"
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:gravity="end">

                <com.google.android.material.button.MaterialButton
                    android:layout_height="50dp"
                    android:layout_width="80dp"
                    app:icon="@drawable/install"
                    app:iconGravity="textStart"
                    app:iconSize="40dp"
                    app:iconPadding="0dp"
                    app:iconTint="@android:color/white"
                    android:backgroundTint="#2E8B57"
                    app:cornerRadius="10dp"
                    android:layout_gravity="center"
                    android:id="@+id/installaplbtn" />

                <com.google.android.material.button.MaterialButton
                    android:layout_height="50dp"
                    android:layout_width="80dp"
                    app:icon="@drawable/play"
                    app:iconGravity="textStart"
                    app:iconSize="40dp"
                    app:iconPadding="0dp"
                    app:iconTint="@android:color/white"
                    android:backgroundTint="#2E8B57"
                    app:cornerRadius="10dp"
                    android:layout_gravity="center"
                    android:id="@+id/startaplbtn" />

                <com.google.android.material.button.MaterialButton
                    android:layout_height="50dp"
                    android:layout_width="80dp"
                    android:layout_marginStart="3dp"
                    android:layout_toEndOf="@+id/startaplbtn"
                    android:backgroundTint="@color/red"
                    app:icon="@drawable/trash"
                    app:iconGravity="textStart"
                    app:iconSize="30dp"
                    app:iconPadding="0dp"
                    app:iconTint="@android:color/white"
                    app:cornerRadius="10dp"
                    android:layout_gravity="center"
                    android:id="@+id/uninstallaplbtn" />

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>